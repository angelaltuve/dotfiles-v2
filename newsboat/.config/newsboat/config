# vim:ft=conf
# Newsboat 

#--- General ---
refresh-on-startup     yes
auto-reload            yes
reload-time            15
reload-threads         10
user-agent             "Mozilla/5.0 (X11; Linux x86_64)"
suppress-first-reload  yes
reload-only-visible-feeds yes
scrolloff              8
ignore-mode            display
confirm-exit           no
cleanup-on-quit        yes
download-retries       5

#--- Display ---
show-keymap-hint       no
swap-title-and-hints   yes
notify-program         "notify-send"
notify-format          "Newsboat: %f unread feeds (%n unread articles)"
display-article-progress yes
text-width             0
wrap-scroll            yes
goto-next-feed         yes
toggleitemread-jumps-to-next-unread yes
openbrowser-and-mark-jumps-to-next-unread yes

#--- Theme (Catppuccin Mocha) ---
color background             default     default
color listnormal             color250    default
color listnormal_unread      color114    default bold
color listfocus              color252    color237 reverse
color listfocus_unread       color114    color237 reverse bold
color info                   color75     default
color title                  color183    default bold
color hint-description       color244    default underline
color article                color252    default
color end-of-text-marker     color242    default

highlight article "(https?|ftp|file)://[-A-Za-z0-9+&@#/%?=~_|!:,.;]*[-A-Za-z0-9+&@#/%=~_|]" color75 default underline
highlight article "^Links:" color244 default underline
highlight article "^(Title|Author|Date|Link):.*" color183 default bold
highlight article "^Feed:.*" color216 default bold
highlight article "\\b(important|breaking|alert|update)\\b" color210 default bold
highlight article "\\b(news|headline|report|source)\\b" color114 default
highlight article "^Podcast Download URL:.*" color114 default
highlight article "\\[[0-9][0-9]*\\]" color147 default bold
highlight article "\\[image [0-9][0-9]*\\]" color147 default bold
highlight article "\\[embedded flash: [0-9][0-9]*\\]" color147 default bold
highlight article ":.*\\(link\\)$" color75 default
highlight article ":.*\\(image\\)$" color79 default
highlight article ":.*\\(embedded flash\\)$" color79 default

#--- Filters ---
ignore-article "*" "link =~ \"youtube\\.com/shorts\""

#--- Macros ---
macro ,     open-in-browser
macro v     set browser "setsid --fork mpv %u > /dev/null 2>&1" ; open-in-browser ; set browser linkhandler
macro c     set browser "printf '%s' %u | kitty +kitten clipboard > /dev/null 2>&1" ; open-in-browser ; set browser linkhandler
macro b     set browser "setsid --fork kitty podboat > /dev/null 2>&1" ; open-in-browser ; set browser linkhandler

#--- Vim-style keys ---
bind-key h          quit
bind-key j          down article
bind-key j          next feedlist
bind-key j          next articlelist
bind-key j          next tagselection
bind-key j          next filterselection
bind-key k          up article
bind-key k          prev feedlist
bind-key k          prev articlelist
bind-key k          prev tagselection
bind-key k          prev filterselection
bind-key J          next-feed articlelist
bind-key J          next-feed feedlist
bind-key K          prev-feed articlelist
bind-key K          prev-feed feedlist
bind-key l          open-in-browser article
bind-key l          open feedlist
bind-key l          open articlelist
bind-key l          open tagselection
bind-key l          open filterselection
bind-key d          pagedown
bind-key u          pageup
bind-key g          home
bind-key G          end
bind-key N          prev-unread
bind-key SPACE      toggle-article-read
bind-key U          show-urls
bind-key S          save
bind-key m          toggle-show-read-feeds
bind-key b          toggle-article-read
bind-key a          mark-all-above-as-read
bind-key ^R         reload-all

# Podboat
bind-key a  pb-download  podboat
bind-key R  pb-delete    podboat

#--- Bookmarks ---
bookmark-cmd       "~/bin/bookmark.sh"
bookmark-autopilot yes

#--- Browser ---
browser            linkhandler
external-url-viewer "xdg-open %u"

#--- Podcasts ---
player             "mpv"
podcast-auto-enqueue yes
save-path          "~/Downloads/newsboat/"
download-path      "~/Downloads/podcasts/"

#--- Files ---
error-log          ~/.local/share/newsboat/error.log
cache-file         ~/.local/share/newsboat/cache.db
datetime-format    "%b %d %R"

