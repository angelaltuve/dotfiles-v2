#!/bin/bash

mode="${1:-fullscreen}"
audio="${2:-monitor}"

if pgrep -f "^gpu-screen-recorder" >/dev/null; then
  pkill -f "^gpu-screen-recorder"
  notify-send -u low "Recording stopped"
  pkill -RTMIN+8 waybar
  exit 0
fi

case "$audio" in
  monitor) audio_opts=(-a default_output); label="Monitor audio" ;;
  mic)     audio_opts=(-a default_input); label="Mic" ;;
  both)    audio_opts=(-a default_output -a default_input); label="Monitor + Mic" ;;
  none)    audio_opts=(); label="Video only" ;;
esac

dest="$XDG_VIDEOS_DIR"
mkdir -p "$dest"
file="$dest/recording-$(date +%Y%m%d-%H%M%S).mp4"

case "$mode" in
  fullscreen)
    gpu-screen-recorder -w screen -f 60 -c mp4 -o "$file" "${audio_opts[@]}" &
    ;;
  region)
    geometry=$(slurp -d) || exit 1
    gpu-screen-recorder -w region -region "$geometry" -f 60 -c mp4 -o "$file" "${audio_opts[@]}" &
    ;;
  focused)
    gpu-screen-recorder -w focused -f 60 -c mp4 -o "$file" "${audio_opts[@]}" &
    ;;
esac

notify-send -u low "Recording started — $label"
pkill -RTMIN+8 waybar
