#!/bin/sh

clip_cmd="xclip -o"
[ "$XDG_SESSION_TYPE" = "wayland" ] && clip_cmd="wl-paste"

url="${1:-$($clip_cmd 2>/dev/null)}"
[ -z "$url" ] && exit 1

open() {
  tmp_file=$(mktemp "/tmp/linkhandler.XXXXXX.jpg")
  curl -fsSL "$1" -o "$tmp_file" &&
    $2 "$tmp_file" &&
    rm -f "$tmp_file"
}

open_img() {
  img="nsxiv -a"
  [ "$XDG_SESSION_TYPE" = "wayland" ] && img="imv"
  open "$1" "$img"
}

case "$url" in
*.mkv | *.webm | *.mp4 | *.MP4 | *.avi | *.mov | \
  *youtube.com/watch?v=* | *youtu.be/* | *youtube.com/embed/* | *youtube.com/shorts/* | *bitchute.com/video/* | *odysee.com/* | \
  *rumble.com/* | *twitch.tv/videos/* | *ok.ru/video/* | *tiktok.com/*/video/* | \
  *ivoox.com/* | *spreaker.com/* | *anchor.fm/* | *podcasts.google.com/* | *podcasts.apple.com/* | *pca.st/* | *player.fm/*)
  setsid -f mpv --quiet "$url" >/dev/null 2>&1 &
  ;;
*.png | *.jpg | *jpg* | *.jpeg | *.jpe | *.gif | *.webp | \
  *yt3.ggpht.com* | *preview.redd*)
  open_img "$url" &
  ;;
*.pdf | *.cbz | *.cbr)
  open "$url" "zathura" &
  ;;
*.mp3 | *.flac | *.opus | *.m4a | *.ogg | *mp3*)
  setsid -f "$TERMINAL" -e mpv "$url" >/dev/null 2>&1 &
  ;;
*.torrent | magnet:* | *.metalink | *.iso | *.img | *.bin | \
  *.tar | *.tar.* | *.tgz | *.txz | *.zip | *.7z | *.rar)
  setsid -f "$TERMINAL" -e "aria2c" "$url" >/dev/null 2>&1 &
  ;;
*)
  if [ -f "$url" ]; then
    setsid -f "$TERMINAL" -e "$EDITOR" "$url" >/dev/null 2>&1
  else
    setsid -f "$BROWSER" "$url" >/dev/null 2>&1
  fi
  ;;
esac
