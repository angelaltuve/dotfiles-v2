#!/bin/sh

[ "${BEMENU_OPTS}" = "" ] \
&& export BEMENU_OPTS="-n -c -s -i \
  -W 0.3 -H 26 -B 2 -l 10 \
  -p '▲' -P '' --ch 16 --scrollbar always \
  --fn 'JetBrainsMono Nerd Font 11' \
  --nb '#1e1e2e' --nf '#cdd6f4' \
  --ab '#1e1e2e' --af '#cdd6f4' \
  --hb '#b4befe' --hf '#1e1e2e' \
  --sb '#b4befe' --sf '#1e1e2e' \
  --fb '#1e1e2e' --ff '#cdd6f4' \
  --fbb '#1e1e2e' --fbf '#cdd6f4' \
  --tb '#1e1e2e' --tf '#cdd6f4' \
  --scb '#1e1e2e' --scf '#cdd6f4' \
  --bdr '#b4befe'"


dir="${PASSWORD_STORE_DIR:-$HOME/.local/share/password-store}"

command -v zbarimg >/dev/null 2>&1 || { notify-send "zbarimg not installed" "Install: pacman -S zbar"; exit 1; }
command -v grim >/dev/null 2>&1 || { notify-send "grim not installed" "Install: pacman -S grim slurp"; exit 1; }
pass otp --help >/dev/null 2>&1 || { notify-send "pass-otp not installed" "Install: yay -S pass-otp oath-toolkit"; exit 1; }

otp_list=$(find "$dir" -maxdepth 1 -name "*-otp.gpg" -printf "%f\n" | sed "s/-otp.gpg//")
choice=$(printf "add\n%s" "$otp_list" | ${DMENU:-bemenu} -p "OTP") || exit 0

case $choice in
  add)
    temp=$(mktemp -p "$XDG_RUNTIME_DIR" --suffix=.png)
    otp="otp-temp"
    trap 'rm -f $temp; pass rm -f $otp' HUP INT QUIT TERM PWR EXIT

    notify-send "OTP" "Select the QR code area"
    grim -g "$(slurp)" "$temp" || exit 1

    info=$(zbarimg -q "$temp")
    info="${info#QR-Code:}"

    if echo "$info" | pass otp insert "$otp"; then
      while true; do
        name=$(printf "" | ${DMENU:-bemenu} -p "Nombre del OTP:")
        echo "$name" | grep -q "^[A-z0-9-]\+$" && break
      done
      pass mv "$otp" "$name-otp"
      notify-send "OTP added" "$name-otp created"
    else
      notify-send "No OTP data" "Could not parse QR code"
    fi
    ;;
  *)
    pass otp -c "$choice-otp"
    notify-send "OTP" "Copied $choice to clipboard"
    ;;
esac
