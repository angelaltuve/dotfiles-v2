#!/bin/bash

DESC="update-$(date +%Y%m%d-%H%M)"

launch-floating-terminal-with-presentation bash -c "
  ~/.local/bin/update-all

  echo -e '\n--- Tareas del sistema post-actualización ---'
  echo 'Creando snapshot de Snapper...'
  sudo snapper -c root create -c number -d \"$DESC\"
  sudo snapper -c root cleanup number
  
  echo 'Actualizando GRUB...'
  sudo grub-mkconfig -o /boot/grub/grub.cfg

  echo -e '\nPress Enter to close.'
  read
"
