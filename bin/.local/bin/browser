#!/bin/sh
# 
# For xdg-open to use this script run:
# xdg-settings set default-web-browser browser.desktop
#
# browser.desktop is located in:
# ~/.local/share/applications/browser.desktop
#
# It contains the following:
#
# [Desktop Entry]
# Type=Application
# Name=browser
# Comment=Browser Picker
# Terminal=false
# Exec=/usr/local/bin/browser
# Categories=Network;WebBrowser
# MimeType=x-scheme-handler/unknown;x-scheme-handler/about;x-scheme-handler/https;x-scheme-handler/http;text/html;


[ "${BEMENU_OPTS}" = "" ] \
&& export BEMENU_OPTS="-n -c -s -i \
  -W 0.3 -H 26 -B 2 -l 10 \
  -p '▲' -P '' --ch 16 --scrollbar always \
  --fn 'JetBrainsMono Nerd Font 11' \
  --nb '#1e1e2e' --nf '#cdd6f4' \
  --ab '#1e1e2e' --af '#cdd6f4' \
  --hb '#b4befe' --hf '#1e1e2e' \
  --sb '#b4befe' --sf '#1e1e2e' \
  --fb '#1e1e2e' --ff '#cdd6f4' \
  --fbb '#1e1e2e' --fbf '#cdd6f4' \
  --tb '#1e1e2e' --tf '#cdd6f4' \
  --scb '#1e1e2e' --scf '#cdd6f4' \
  --bdr '#b4befe'"


unset GDK_BACKEND

url="$1"
host=$(url-parser --url host "$url" 2>/dev/null || echo "$url")

if echo "$host" | grep -qi '\.onion$'; then
  selected="tor-browser"
else
  selected=$(printf "copy\nchromium\nlibrewolf" | bemenu -p "browser")
fi

case $selected in
  "copy")
    exec wl-copy "$url"
    ;;
  "firefox")
    exec /usr/local/bin/firefox "$url"
    ;;
  "librewolf")
    exec /usr/bin/librewolf "$url"
    ;; 
  "chromium")
    exec chromium --force-dark-mode --enable-features=WebUIDarkMode "$url"
    ;;
  "tor-browser")
    exec /usr/local/bin/tor-browser "$url"
    ;;
  *)
    exit 0
    ;;
esac

