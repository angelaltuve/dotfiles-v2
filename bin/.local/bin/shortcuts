#!/usr/bin/env bash
set -euo pipefail

if [[ -t 1 ]]; then
  exec less -R < <("$0" --raw)
fi

print_header() {
  echo -e "\033[1;34m━━━ $1 ━━━\033[0m"
}

print_key() {
  printf "  \033[1;33m%-24s\033[0m %s\n" "$1" "$2"
}

if [[ -f "$HOME/.config/sway/config" ]]; then
  print_header "Sway"
  grep -E '^\s*(bindsym|bindcode)\s' "$HOME/.config/sway/config" \
    | grep -v '^\s*#' \
    | awk '{
        key = $2
        $1 = ""; $2 = ""
        sub(/^ */, "")
        printf "  \033[1;33m%-24s\033[0m %s\n", key, $0
      }'
fi

print_header "Neovim"
awk -F'"' '
  /vim\.keymap\.set/ {
    mode = $2
    key = $4
    if (match($0, /desc = "([^"]+)"/)) {
      desc = substr($0, RSTART+7, RLENGTH-8)
      printf "  \033[1;33m%-24s\033[0m [%s] %s\n", key, mode, desc
    }
  }
' "$HOME/.config/nvim/init.lua" | sort -t'[' -k2
