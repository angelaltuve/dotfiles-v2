#!/bin/bash

configs=(/etc/wireguard/*.conf)
(( ${#configs[@]} )) || { notify-send -u low "No WireGuard configs in /etc/wireguard/"; exit 1; }

declare -A active
while IFS= read -r iface; do active[$iface]=1; done < <(wg show 2>/dev/null | awk '/^interface/{print $2}')

list=()
for conf in "${configs[@]}"; do
  name=${conf##*/}; name=${name%.conf}
  list+=("${active[$name]:+}  $name")
done

choice=$(printf '%s\n' "${list[@]}" | rofi -dmenu -p "WireGuard" -i) || exit 0

name="${choice##*  }"

case ${choice%% *} in
  ) sudo wg-quick down "$name" && notify-send -u low "WireGuard: $name disconnected";;
  ) sudo wg-quick up "$name" && notify-send -u low "WireGuard: $name connected";;
esac

pkill -RTMIN+11 waybar 2>/dev/null || true
