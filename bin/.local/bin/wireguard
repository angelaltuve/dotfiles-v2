#!/bin/bash

configs=$(find /etc/wireguard -maxdepth 1 -name "*.conf" -printf "%f\n" | sed 's/\.conf$//')
[[ -z $configs ]] && { notify-send -u low "No WireGuard configs in /etc/wireguard/"; exit 1; }

active=$(wg show 2>/dev/null | grep ^interface | awk '{print $2}')

list=""
while IFS= read -r c; do
  if echo "$active" | grep -qxF "$c"; then
    list+="’Ćī  $c\n"
  else
    list+="’äī  $c\n"
  fi
done <<< "$configs"

choice=$(echo -e "$list" | ${DMENU:-bemenu} -p "WireGuard") || exit 0

name="${choice#*  }"

case $choice in
  ’Ćī*)
    sudo wg-quick down "$name" && notify-send -u low "WireGuard: $name disconnected"
    ;;
  ’äī*)
    sudo wg-quick up "$name" && notify-send -u low "WireGuard: $name connected"
    ;;
esac

pkill -RTMIN+11 waybar 2>/dev/null || true
