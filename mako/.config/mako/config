anchor=top-right
group-by=app-name,summary,body
default-timeout=5000
width=360
outer-margin=15
padding=8,12
border-size=1
border-color=#45475a
background-color=#1e1e2e
text-color=#cdd6f4
max-icon-size=24
font=Ubuntu Regular 12
icons=1
[urgency=low]
border-color=#a6adc8

[urgency=normal]
border-color=#89b4fa

[urgency=critical]
default-timeout=0
layer=overlay
border-color=#f38ba8

[app-name=Spotify]
invisible=1

[mode=do-not-disturb]
invisible=true

[mode=do-not-disturb app-name=notify-send]
invisible=false

[summary~="Setup Wi-Fi"]
on-button-left=exec sh -c 'launch-wifi'

[summary~="Screenshot copied & saved"]
max-icon-size=80
format=<b>%s</b>\n%b
